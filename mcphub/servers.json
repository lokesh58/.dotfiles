{
  "mcpServers": {
    "context7": {
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "command": "npx",
      "env": {
        "DEFAULT_MINIMUM_TOKENS": "5000"
      }
    },
    "sequentialthinking": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "command": "npx"
    },
    "tavily": {
      "args": [
        "-y",
        "tavily-mcp"
      ],
      "command": "npx",
      "env": {
        "TAVILY_API_KEY": "${cmd:echo $TAVILY_API_KEY}"
      }
    }
  }
}
