[core]
    autocrlf = true
    editor = nvim

[gpg]
    format = ssh

[commit]
    gpgsign = true

[init]
    defaultBranch = main

[push]
    autoSetupRemote = true

[include]
    # Include user details from local file
    path = ~/.dotfiles/git/gitconfig.local

[includeIf "gitdir:C:/"]
    # Include Windows-specific configuration if on Windows (C: drive)
    path = ~/.dotfiles/git/gitconfig.windows
